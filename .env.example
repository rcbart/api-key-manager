# ──────────────────────────────────────────────────────────────────────────────
# API Key Manager — environment variable template
#
# Copy this file to .env and fill in every value before starting the stack.
# The .env file is listed in .gitignore and must NEVER be committed to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=apikey
POSTGRES_PASSWORD=changeme_strong_db_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRATION_MINUTES=60

# ── First admin account (created on first boot if no admin exists) ────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_admin_password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to the URL the browser will use to reach the app.
# In a local Docker setup this is typically http://localhost.
# In production use the real HTTPS URL (e.g. https://keys.example.com).
CORS_ORIGIN=http://localhost

# ── Frontend port (host port mapped to nginx port 80 inside the container) ───
FRONTEND_PORT=80
